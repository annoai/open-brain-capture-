# ─────────────────────────────────────────────────────────────────────────────
# Open Brain Capture — environment variables
#
# Copy this file to .env.local for local development.
# In production (Vercel), set these in the Vercel dashboard under
# Project → Settings → Environment Variables.
#
# These are SERVER-SIDE ONLY variables (no VITE_ prefix).
# They are used by api/capture.js (Vercel serverless function) and are
# never bundled into the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL of your Supabase Edge Function
# Example: https://abcdefghijkl.supabase.co/functions/v1/open-brain-mcp
OPEN_BRAIN_API_URL=

# Your MCP_ACCESS_KEY secret (set in Supabase → Project → Edge Functions → Secrets)
OPEN_BRAIN_ACCESS_KEY=
